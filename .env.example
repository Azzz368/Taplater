# Leave this as mock for a key-free local canvas.
AI_PROVIDER=mock

# 302.AI server-only configuration. Put real values in .env.local, never in NEXT_PUBLIC_ variables.
AI_302_API_KEY=
AI_302_API_ORIGIN=https://api.302.ai
AI_302_BASE_URL=https://api.302.ai/v1
AI_302_OPENAI_BASE_URL=https://api.302.ai/v1

# Model defaults
AI_302_TEXT_MODEL=gpt-4o-mini
AI_302_STORYBOARD_MODEL=gpt-4o-mini
AI_302_IMAGE_MODEL=gpt-image-2
AI_302_VIDEO_MODEL=minimaxi-t2v-01
AI_302_TTS_MODEL=doubao
AI_302_TTS_VOICE=zh_male_beijingxiaoye_emo_v2_mars_bigtts

# Request behavior
AI_302_TIMEOUT_MS=120000
AI_302_POLL_INTERVAL_MS=3000
